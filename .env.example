# Exodus configuration — copy to `.env` and fill in. NEVER commit `.env`.

# --- Upstream (the real cloud provider) ---
# Your real Anthropic key. It lives ONLY on this machine; Exodus forwards with it.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# Where Exodus forwards the (sanitized) traffic. PROVIDER-NEUTRAL:
#   Anthropic (Claude Code):  https://api.anthropic.com
#   OpenAI    (Codex CLI):    https://api.openai.com
# One Exodus instance = one upstream. Run a 2nd instance on another port for a 2nd provider.
EXODUS_UPSTREAM=https://api.anthropic.com

# --- Exodus proxy (what Claude Code points to via ANTHROPIC_BASE_URL) ---
EXODUS_HOST=127.0.0.1
EXODUS_PORT=8787

# --- Local model layer (M4 — OPTIONAL "privacy brain": classify + abstract free text). ---
# OFF by default. The deterministic firewall (regex + validators) works WITHOUT this.
EXODUS_LOCAL_MODEL=
# Backend: "embedded" (default — in-process llama.cpp, NO Ollama; downloads a small model
# once, then fully offline) or "ollama" (use a separate Ollama daemon you already run).
EXODUS_LOCAL_BACKEND=embedded

# Embedded backend (needs: pip install -e ".[local]"). Small + multilingual by default.
EXODUS_EMBED_REPO=Qwen/Qwen2.5-1.5B-Instruct-GGUF
EXODUS_EMBED_FILE=*q4_k_m.gguf
# Or point to a GGUF you already downloaded (skips the network fetch entirely):
EXODUS_EMBED_MODEL_PATH=

# Ollama backend (only used when EXODUS_LOCAL_BACKEND=ollama):
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# --- Policy & audit ---
EXODUS_POLICY_FILE=src/exodus/policy/policy.example.yaml
EXODUS_AUDIT_LOG=audit/exodus.jsonl
# Keep the vault in memory only (recommended). Set to a path only for debugging.
EXODUS_VAULT_PERSIST=

# --- Inspection / debug log (OPT-IN · DANGER: full plaintext incl. secrets) ---
# Captures BOTH sides of YOUR OWN exchange (what you wrote / what was sent / what was
# received) so you can verify Exodus. OFF by default. Debug only — delete when done.
# NEVER use to capture someone else's session without consent.
EXODUS_INSPECT=
EXODUS_INSPECT_LOG=inspect/exodus-inspect.jsonl

# --- Proof mode (OPT-IN · demo only) ---
# Keep the outbound masking but DO NOT restore the response, so YOUR client shows the
# placeholders the cloud actually received — visual proof the real secret never left.
# Breaks normal use (placeholders leak into output). Turn OFF when done demonstrating.
EXODUS_NO_RESTORE=
